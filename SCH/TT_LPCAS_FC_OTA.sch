C {devices/code_shown.sym} -380 -780 0 0 {name="DC_OP_SIMS" only_toplevel=true 
value="
.option wnflag=1 gmin=1e-18
.option savecurrents
.temp 27
.control
save all
op
write TT_LPCAS_FC_OTA.raw
set appendwrite 
ac dec 20 1 1e10
let phase_mb = 180/PI*vp(Vout)
plot vdb(Vout) phase_mb
write TT_LPCAS_FC_OTA.raw
.endc
"
}
